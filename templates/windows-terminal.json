            },
            {
                "guid": "{2ddef6ea-68bf-5428-b02e-81f2f674666d}",
                "hidden": true,
                "name": "Developer Command Prompt for VS 18",
                "source": "Windows.Terminal.VisualStudio"
            },
            {
                "guid": "{e5a186de-d213-5de0-a4fc-b5df54c37762}",
